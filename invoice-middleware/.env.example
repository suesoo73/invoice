APP_NAME=invoice-middleware
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080

MYSQL_HOST=192.168.20.10
MYSQL_PORT=3306
MYSQL_DATABASE=invoice_ocr
MYSQL_USER=invoice_app
MYSQL_PASSWORD=change_me

OLLAMA_BASE_URL=http://127.0.0.1:11434
# invoice-app의 DEFAULT_OCR_MODEL과 같은 값으로 맞춰 사용
OLLAMA_MODEL=qwen3.5:9B
OLLAMA_ALLOWED_MODELS=qwen3.5:9B,gemma4:e4b
OCR_MAX_PDF_PAGES=4

STORAGE_ROOT=/home/suesoo/invoice-storage
WEB_APP_ALLOWED_ORIGIN=https://invoice.nusome.co.kr
INTERNAL_SHARED_TOKEN=change_me
OCR_MAX_RETRIES=2
WORKER_STALE_AFTER_SECONDS=600
